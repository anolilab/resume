{
    "name": "@anolilab/resume",
    "version": "0.0.0",
    "private": true,
    "description": "My personal resume",
    "repository": {
        "type": "git",
        "url": "https://github.com/anolilab/resume.git"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de",
        "url": "https://www.danielbannert.com"
    },
    "sideEffects": false,
    "scripts": {
        "audit": "audit-ci --config ./audit-ci.jsonc",
        "build": "tsc && cross-env NODE_ENV='production' vite build",
        "build:pdf": "esno ./bin/build-pdf.ts",
        "clean": "rimraf node_modules dist",
        "commit": "cz",
        "dev": "vite",
        "download:resume": "esno ./bin/download-resume-gist.ts",
        "lint": "pnpm run lint:text && pnpm run lint:prettier && pnpm run lint:eslint",
        "lint:commits": "pnpm commitlint --from HEAD~1 --to HEAD --verbose",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --fix",
        "lint:fix": "pnpm run lint:text:fix && pnpm run lint:prettier:fix && pnpm run lint:eslint:fix",
        "lint:prettier": "prettier --config=.prettierrc.cjs '**/*.{js,jsx,tsx,ts,less,md,json,html}'",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write '**/*.{js,jsx,tsx,ts,less,md,json}'",
        "lint:secrets": "secretlint **/*",
        "lint:text": "textlint ./.github/ISSUE_TEMPLATE/** ./README.md ./UPGRADE.md --experimental --dry-run",
        "lint:text:fix": "textlint ./.github/ISSUE_TEMPLATE/** ./README.md ./UPGRADE.md --experimental --fix",
        "prepare": "is-ci || (node verify-node-version.cjs && pnpx only-allow pnpm && husky install)",
        "serve": "vite preview",
        "sort-package-json": "sort-package-json ./package.json",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@anolilab/resume-schema": "catalog:",
        "@fontsource/noto-sans-sc": "catalog:",
        "@fontsource/nunito": "catalog:",
        "@octokit/rest": "catalog:",
        "ajv": "catalog:",
        "ajv-formats": "catalog:",
        "date-fns": "catalog:",
        "deepmerge": "catalog:",
        "esno": "catalog:",
        "gravatar": "catalog:",
        "lodash.capitalize": "catalog:",
        "puppeteer": "catalog:"
    },
    "devDependencies": {
        "@anolilab/commitlint-config": "catalog:",
        "@anolilab/eslint-config": "catalog:",
        "@anolilab/lint-staged-config": "catalog:",
        "@anolilab/prettier-config": "catalog:",
        "@anolilab/semantic-release-preset": "catalog:",
        "@anolilab/textlint-config": "catalog:",
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@eslint/css": "catalog:",
        "@tailwindcss/postcss": "catalog:",
        "@types/gravatar": "catalog:",
        "@types/lodash.capitalize": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "audit-ci": "catalog:",
        "c8": "catalog:",
        "commitizen": "catalog:",
        "cross-env": "catalog:",
        "cssnano": "catalog:",
        "eslint": "catalog:",
        "handlebars": "catalog:",
        "husky": "catalog:",
        "is-ci": "catalog:",
        "lint-staged": "catalog:",
        "postcss": "catalog:",
        "prettier": "catalog:",
        "semantic-release": "catalog:",
        "sort-package-json": "catalog:",
        "tailwindcss": "catalog:",
        "textlint": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-favicon2": "catalog:",
        "vite-plugin-handlebars": "catalog:",
        "vite-plugin-static-copy": "catalog:",
        "vitest": "catalog:"
    },
    "packageManager": "pnpm@11.5.3",
    "engines": {
        "node": ">=22"
    }
}
